# ═══════════════════════════════════════════════════════════════
# GuideTranslator Sales — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (REQUIRED — frontend + backend) ─────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase Service Key (REQUIRED — backend/API routes only) ─
# Used by webhooks, cron jobs, and admin API routes
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Admin Password (REQUIRED) ────────────────────────────────
# Used for legacy admin login (before Supabase Auth migration)
VITE_ADMIN_PASSWORD=your-secure-admin-password-here

# ─── Stripe (REQUIRED for payments) ───────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Found in: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Resend (REQUIRED for transactional emails) ──────────────
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_xxx

# ─── Email Configuration ─────────────────────────────────────
EMAIL_FROM=GuideTranslator <enterprise@guidetranslator.com>

# ─── App URL (REQUIRED for email links + Stripe redirects) ───
APP_URL=https://sales.guidetranslator.com

# ─── Cron Secret (REQUIRED for scheduled follow-ups) ─────────
# Any random string to protect /api/check-followups
CRON_SECRET=your-random-cron-secret-here

# ─── Seed Admin Secret (for one-time setup only) ─────────────
SEED_SECRET=your-random-seed-secret-here
